{
  "name": "l2",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "USE_LOCAL_CONVEX=true vite dev --port 5296",
    "dev:hosted": "vite dev --port 5296",
    "dev:web": "vite dev --port 5296",
    "build": "vite build",
    "build:vercel": "bunx convex deploy --cmd 'bun run build' --cmd-url-env-var-name VITE_CONVEX_URL",
    "start": "vite preview --port 5296",
    "check": "bun run lint && bun run typecheck && bun run typecheck:convex",
    "format": "eslint src convex --fix --ignore-pattern 'convex/_generated/**'",
    "lint": "eslint src convex --ignore-pattern 'convex/_generated/**'",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "typecheck:convex": "bunx convex typecheck",
    "generate:og": "bun run scripts/generate-og.tsx"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1007.0",
    "@aws-sdk/s3-request-presigner": "^3.1007.0",
    "@clerk/clerk-js": "^6.3.0",
    "@convex-dev/presence": "^0.3.0",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@mux/mux-node": "^12.8.1",
    "atmn": "^1.1.3",
    "autumn-js": "^0.1.85",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.32.0",
    "convex-svelte": "^0.0.12",
    "hls.js": "^1.6.15",
    "lucide-svelte": "^0.577.0",
    "nanoid": "^5.1.6",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.54.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^20.19.37",
    "eslint": "^9.39.4",
    "satori": "^0.19.3",
    "sharp": "^0.34.5",
    "svelte": "^5.53.10",
    "svelte-check": "^4.4.5",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "6"
  },
  "type": "module"
}
