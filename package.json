{
  "name": "l2",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "USE_LOCAL_CONVEX=true vite dev --port 5296",
    "dev:hosted": "vite dev --port 5296",
    "dev:web": "vite dev --port 5296",
    "build": "vite build",
    "build:vercel": "bunx convex deploy --cmd 'bun run build' --cmd-url-env-var-name VITE_CONVEX_URL",
    "start": "vite preview --port 5296",
    "check": "bun run lint && bun run typecheck && bun run typecheck:convex",
    "format": "eslint app src convex --fix --ignore-pattern 'convex/_generated/**'",
    "lint": "eslint app src convex --ignore-pattern 'convex/_generated/**'",
    "typecheck": "tsc --noEmit",
    "typecheck:convex": "bunx convex typecheck",
    "generate:og": "bun run scripts/generate-og.tsx"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1007.0",
    "@aws-sdk/s3-request-presigner": "^3.1007.0",
    "@clerk/tanstack-react-start": "^0.27.17",
    "@convex-dev/presence": "^0.3.0",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@mux/mux-node": "^12.8.1",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-router": "^1.166.7",
    "@tanstack/react-router-devtools": "^1.166.7",
    "@tanstack/react-start": "^1.166.8",
    "atmn": "^1.1.3",
    "autumn-js": "^0.1.85",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.32.0",
    "hls.js": "^1.6.15",
    "isbot": "^5.1.36",
    "lucide-react": "^0.563.0",
    "nanoid": "^5.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.5.0",
    "video.js": "^8.23.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sharp": "^0.32.0",
    "@types/video.js": "^7.3.58",
    "@vitejs/plugin-react": "^5.1.4",
    "convex-vite-plugin": "^0.4.0",
    "eslint": "^9.39.4",
    "satori": "^0.19.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "type": "module"
}
