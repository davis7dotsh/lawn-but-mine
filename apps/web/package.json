{
  "name": "@lawn/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "USE_LOCAL_CONVEX=true vite dev",
    "dev:hosted": "vite dev",
    "build": "vite build",
    "start": "vite preview --port 5296",
    "check": "bun run lint && bun run typecheck",
    "format": "eslint \"src/**/*.{ts,js}\" \"scripts/**/*.ts\" vite.config.ts svelte.config.js --fix --ignore-pattern '**/*.svelte.ts'",
    "lint": "eslint \"src/**/*.{ts,js}\" \"scripts/**/*.ts\" vite.config.ts svelte.config.js --ignore-pattern '**/*.svelte.ts'",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.app.json",
    "generate:og": "bun run scripts/generate-og.ts"
  },
  "dependencies": {
    "@clerk/clerk-js": "^6.3.0",
    "@clerk/ui": "^1.2.1",
    "@lawn/convex": "workspace:*",
    "@lawn/shared": "workspace:*",
    "clsx": "^2.1.1",
    "convex": "^1.32.0",
    "convex-svelte": "^0.0.12",
    "hls.js": "^1.6.15",
    "isbot": "^5.1.36",
    "lucide-svelte": "^0.577.0",
    "nanoid": "^5.1.6",
    "tailwind-merge": "^3.5.0",
    "video.js": "^8.23.7"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.54.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/sharp": "^0.32.0",
    "@types/video.js": "^7.3.58",
    "convex-vite-plugin": "^0.4.0",
    "satori": "^0.19.3",
    "sharp": "^0.34.5",
    "svelte": "^5.53.10",
    "svelte-check": "^4.4.5",
    "tailwindcss": "^4.2.1",
    "vite": "^7.3.1"
  }
}
