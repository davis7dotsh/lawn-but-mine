# Public client env
# Local dev defaults to http://127.0.0.1:3210 via `bun run dev`.
VITE_CONVEX_URL=https://your-deployment.convex.cloud
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key

# Clerk server / Convex auth env
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_JWT_ISSUER_DOMAIN=https://your-clerk-domain.clerk.accounts.dev

# Mux env
MUX_TOKEN_ID=your_mux_token_id
MUX_TOKEN_SECRET=your_mux_token_secret
MUX_SIGNING_KEY=your_mux_signing_key_id
MUX_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
MUX_WEBHOOK_SECRET=your_mux_webhook_secret

# Legacy Mux names still accepted by the codebase
# MUX_SIGNING_KEY_ID=your_mux_signing_key_id
# MUX_SIGNING_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Autumn billing env
AUTUMN_SECRET_KEY=your_autumn_secret_key
# Optional override. Defaults to Autumn's hosted API.
AUTUMN_URL=https://api.useautumn.com

# Railway object storage env
RAILWAY_ACCESS_KEY_ID=your_railway_access_key_id
RAILWAY_SECRET_ACCESS_KEY=your_railway_secret_access_key
RAILWAY_ENDPOINT=https://your-railway-s3-endpoint
RAILWAY_PUBLIC_URL=https://your-public-bucket-url
RAILWAY_BUCKET_NAME=videos
RAILWAY_REGION=us-east-1
RAILWAY_PUBLIC_URL_INCLUDE_BUCKET=true

# Convex / deploy env
CONVEX_DEPLOYMENT=your_convex_deployment_name
CONVEX_DEPLOY_KEY=your_convex_deploy_key

# Mentioned in docs/setup.md, but not currently read in app source
VITE_CONVEX_SITE_URL=https://your-deployment.convex.site
